// Печать «Счет-оферта» — MXL-макет (layout MCP). Области как в типовом счёте БП.

#Область ПрограммныйИнтерфейс

Процедура Печать(МассивОбъектов, ПараметрыПечати, КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрыВывода) Экспорт
	
	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "ГСК5664_СчетОферта") Тогда
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(
			КоллекцияПечатныхФорм, "ГСК5664_СчетОферта", "Счет-оферта",
			СформироватьПечатнуюФорму(МассивОбъектов, ОбъектыПечати), ,
			ГСК5664_ПолныйПутьКМакетуСчетОферта());
	КонецЕсли;
	
КонецПроцедуры

Функция СформироватьПечатнуюФорму(МассивОбъектов, ОбъектыПечати) Экспорт
	
	Макет = УправлениеПечатью.МакетПечатнойФормы(ГСК5664_ПолныйПутьКМакетуСчетОферта());
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.АвтоМасштаб = Истина;
	
	Для Каждого СсылкаСчета Из МассивОбъектов Цикл
		ГСК5664_ВывестиСчетВТабличныйДокумент(ТабличныйДокумент, Макет, СсылкаСчета);
	КонецЦикла;
	
	Возврат ТабличныйДокумент;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ГСК5664_ПолныйПутьКМакетуСчетОферта()
	
	Возврат "Документ.СчетНаОплатуПокупателю.ПФ_MXL_СчетОферта";
	
КонецФункции

Процедура ГСК5664_ВывестиСчетВТабличныйДокумент(ТабличныйДокумент, Макет, СсылкаСчета)
	
	Сведения = ГСК5664_СведенияСчета(СсылкаСчета);
	
	ГСК5664_ВывестиЗаголовокСчета(ТабличныйДокумент, Макет, Сведения);
	
	ДанныеШапки = ГСК5664_ДанныеШапки(СсылкаСчета, Сведения);
	ГСК5664_ВывестиОбласть(ТабличныйДокумент, Макет, "Заголовок", Новый Структура("ТекстЗаголовка", ДанныеШапки.ТекстЗаголовка));
	ГСК5664_ВывестиОбласть(ТабличныйДокумент, Макет, "Поставщик",
		Новый Структура("ПредставлениеПоставщика", ДанныеШапки.ПредставлениеПоставщика));
	ГСК5664_ВывестиОбласть(ТабличныйДокумент, Макет, "Покупатель",
		Новый Структура("ПредставлениеПокупателя, Основание", ДанныеШапки.ПредставлениеПокупателя, ДанныеШапки.Основание));
	
	Итоги = ГСК5664_ВывестиТабличнуюЧасть(ТабличныйДокумент, Макет, Сведения);
	ГСК5664_ВывестиИтогиПодвалИУсловия(ТабличныйДокумент, Макет, Сведения, Итоги, ДанныеШапки);
	
КонецПроцедуры

Функция ГСК5664_ВывестиТабличнуюЧасть(ТабличныйДокумент, Макет, Сведения)
	
	ВыводитьКоды = ГСК5664_ВыводитьКодыВТаблице();
	ЕстьСкидка = (Сведения.ТаблицаДокумента.Итог("СуммаСкидки") <> 0)
		И ЗначениеЗаполнено(Макет.Области.Найти("Скидка"));
	
	ОбластьНомера = Макет.ПолучитьОбласть("ШапкаТаблицы|НомерСтроки");
	ОбластьКодов = Макет.ПолучитьОбласть("ШапкаТаблицы|КолонкаКодов");
	ОбластьДанных = Макет.ПолучитьОбласть("ШапкаТаблицы|Данные");
	ОбластьСуммы = Макет.ПолучитьОбласть("ШапкаТаблицы|Сумма");
	
	НачалоНовогоФормата = ТабличныйДокумент.ВысотаТаблицы;
	
	ТабличныйДокумент.Вывести(ОбластьНомера);
	Если ВыводитьКоды Тогда
		ДанныеКолонкиКодов = Новый Структура;
		Если ГСК5664_ИмяКолонкиКодов() = "Артикул" Тогда
			ДанныеКолонкиКодов.Вставить("ИмяКолонкиКодов", "Артикул");
		Иначе
			ДанныеКолонкиКодов.Вставить("ИмяКолонкиКодов", "Код");
		КонецЕсли;
		ОбластьКодов.Параметры.Заполнить(ДанныеКолонкиКодов);
		ТабличныйДокумент.Присоединить(ОбластьКодов);
	КонецЕсли;
	ТабличныйДокумент.Присоединить(ОбластьДанных);
	Если ЕстьСкидка Тогда
		ТабличныйДокумент.Присоединить(Макет.ПолучитьОбласть("ШапкаТаблицы|Скидка"));
	КонецЕсли;
	ГСК5664_ПрисоединитьКолонкиНДС(ТабличныйДокумент, Макет, "ШапкаТаблицы");
	ТабличныйДокумент.Присоединить(ОбластьСуммы);
	
	ГСК5664_ПодготовитьШиринуКолонокТаблицы(Макет, ВыводитьКоды, ЕстьСкидка);
	
	ОбластьНомера = Макет.ПолучитьОбласть("Строка|НомерСтроки");
	ОбластьКодов = Макет.ПолучитьОбласть("Строка|КолонкаКодов");
	ОбластьДанных = Макет.ПолучитьОбласть("Строка|Данные");
	ОбластьСуммы = Макет.ПолучитьОбласть("Строка|Сумма");
	
	НомерСтроки = 0;
	Для Каждого Строка Из Сведения.ТаблицаДокумента Цикл
		НомерСтроки = НомерСтроки + 1;
		ОбластьНомера.Параметры.Заполнить(Новый Структура("НомерСтроки", НомерСтроки));
		ТабличныйДокумент.Вывести(ОбластьНомера);
		
		Если ВыводитьКоды Тогда
			ОбластьКодов.Параметры.Заполнить(Новый Структура("Артикул", Строка.НоменклатураАртикул));
			ТабличныйДокумент.Присоединить(ОбластьКодов);
		КонецЕсли;
		
		ДанныеСтроки = Новый Структура;
		ДанныеСтроки.Вставить("Товар", СокрЛП(Строка.НоменклатураНаименование));
		ДанныеСтроки.Вставить("Количество", Строка.Количество);
		ДанныеСтроки.Вставить("ЕдиницаИзмерения", Строка.ЕдиницаИзмеренияНаименование);
		ДанныеСтроки.Вставить("Цена", ОбщегоНазначенияБПВызовСервера.ФорматСумм(Строка.Цена));
		ОбластьДанных.Параметры.Заполнить(ДанныеСтроки);
		ТабличныйДокумент.Присоединить(ОбластьДанных);
		
		Если ЕстьСкидка Тогда
			ОбластьСкидки = Макет.ПолучитьОбласть("Строка|Скидка");
			ОбластьСкидки.Параметры.Заполнить(Новый Структура("СуммаСкидки",
				ОбщегоНазначенияБПВызовСервера.ФорматСумм(Строка.СуммаСкидки)));
			ТабличныйДокумент.Присоединить(ОбластьСкидки);
		КонецЕсли;
		
		ГСК5664_ПрисоединитьКолонкиНДС(ТабличныйДокумент, Макет, "Строка",
			ГСК5664_ДанныеСтрокиНДС(Строка, Сведения));
		
		СуммаСтроки = Строка.Сумма - Строка.СуммаСкидки;
		ОбластьСуммы.Параметры.Заполнить(Новый Структура(
			"Сумма", ОбщегоНазначенияБПВызовСервера.ФорматСумм(СуммаСтроки)));
		ТабличныйДокумент.Присоединить(ОбластьСуммы);
	КонецЦикла;
	
	ТабличныйДокумент.Область(НачалоНовогоФормата + 1,, ТабличныйДокумент.ВысотаТаблицы).СоздатьФорматСтрок();
	
	Итоги = ГСК5664_РассчитатьИтоги(Сведения);
	Итоги.Вставить("НомерСтроки", НомерСтроки);
	Возврат Итоги;
	
КонецФункции

Процедура ГСК5664_ВывестиИтогиПодвалИУсловия(ТабличныйДокумент, Макет, Сведения, Итоги, ДанныеШапки)
	
	Сумма = Итоги.Сумма;
	СуммаНДС = Итоги.СуммаНДС;
	НомерСтроки = Итоги.НомерСтроки;
	ВыводитьКоды = ГСК5664_ВыводитьКодыВТаблице();
	ЕстьСкидка = (Сведения.ТаблицаДокумента.Итог("СуммаСкидки") <> 0)
		И ЗначениеЗаполнено(Макет.Области.Найти("Скидка"));
	
	ДанныеПечатиИтоговНДС = ГСК5664_ДанныеПечатиИтоговНДС(Сведения, СуммаНДС);
	
	ДанныеЗаполненияИтого = Новый Структура("Всего", ОбщегоНазначенияБПВызовСервера.ФорматСумм(Сумма));
	СуммаКОплате = Сумма + ?(Сведения.СуммаВключаетНДС, 0, СуммаНДС);
	ДанныеИтогоКОплате = Новый Структура("ИтогоКОплате", ОбщегоНазначенияБПВызовСервера.ФорматСумм(СуммаКОплате));
	
	Если ГСК5664_ЕстьОбласть(Макет, "Подвал") Тогда
		ГСК5664_ВывестиОбласть(ТабличныйДокумент, Макет, "Подвал");
	КонецЕсли;
	
	Если Сведения.СуммаСкидки <> 0 И ГСК5664_ЕстьОбласть(Макет, "СкидкаПоДокументу") Тогда
		ГСК5664_ВывестиОбласть(ТабличныйДокумент, Макет, "СкидкаПоДокументу",
			Новый Структура("СуммаСкидки", ОбщегоНазначенияБПВызовСервера.ФорматСумм(Сведения.СуммаСкидки)));
	КонецЕсли;
	
	// Без скидки — составные строки в колонках таблицы; со скидкой — целые области макета.
	Если ЕстьСкидка Тогда
		ГСК5664_ВывестиОбласть(ТабличныйДокумент, Макет, "Итого", ДанныеЗаполненияИтого);
		ГСК5664_ВывестиОбласть(ТабличныйДокумент, Макет, "ИтогоНДС", ДанныеПечатиИтоговНДС);
		ГСК5664_ВывестиОбласть(ТабличныйДокумент, Макет, "ИтогоКОплате", ДанныеИтогоКОплате);
	Иначе
		ГСК5664_ВывестиСоставнуюСтрокуИтога(ТабличныйДокумент, Макет, "Итого", ДанныеЗаполненияИтого, ВыводитьКоды);
		ГСК5664_ВывестиСоставнуюСтрокуИтогаНДС(ТабличныйДокумент, Макет, ДанныеПечатиИтоговНДС, ВыводитьКоды);
		ГСК5664_ВывестиСоставнуюСтрокуИтога(ТабличныйДокумент, Макет, "ИтогоКОплате", ДанныеИтогоКОплате, ВыводитьКоды);
	КонецЕсли;
	
	Если ГСК5664_ЕстьОбласть(Макет, "СуммаПрописью") Тогда
		ДанныеПрописью = Новый Структура("ИтоговаяСтрока, СуммаПрописью");
		ДанныеПрописью.ИтоговаяСтрока = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru = 'Всего наименований %1, на сумму %2'"),
			НомерСтроки,
			ОбщегоНазначенияБПВызовСервера.ФорматСумм(СуммаКОплате, Сведения.Валюта));
		ДанныеПрописью.СуммаПрописью = ОбщегоНазначенияБПВызовСервера.СформироватьСуммуПрописью(СуммаКОплате, Сведения.Валюта);
		ГСК5664_ВывестиОбласть(ТабличныйДокумент, Макет, "СуммаПрописью", ДанныеПрописью);
	КонецЕсли;
	
	Если ГСК5664_ЕстьОбласть(Макет, "ДополнительныеУсловия") Тогда
		ГСК5664_ВывестиОбласть(ТабличныйДокумент, Макет, "ДополнительныеУсловия",
			Новый Структура("ТекстДополнительныхУсловий", ДанныеШапки.ТекстДополнительныхУсловий));
	КонецЕсли;
	
	ГСК5664_ВывестиПодписи(ТабличныйДокумент, Макет, Сведения);
	
КонецПроцедуры

Функция ГСК5664_РассчитатьИтоги(Сведения)
	
	Сумма = Сведения.ТаблицаДокумента.Итог("Сумма");
	СуммаНДС = Сведения.ТаблицаДокумента.Итог("СуммаНДС");
	ВсегоСкидок = Сведения.ТаблицаДокумента.Итог("СуммаСкидки");
	
	Если Сведения.СуммаСкидки <> 0 Тогда
		ДанныеОбъекта = Новый Структура("СуммаСкидки, СуммаВключаетНДС");
		ЗаполнитьЗначенияСвойств(ДанныеОбъекта, Сведения);
		ТаблицаТовары = Сведения.ТаблицаДокумента.Скопировать();
		ОбработкаТабличныхЧастей.РаспределитьСкидкуПоСтрокамТабЧасти(ТаблицаТовары, ДанныеОбъекта);
		Всего = Сумма + ?(Сведения.СуммаВключаетНДС, 0, СуммаНДС);
		СуммаНДС = ТаблицаТовары.Итог("СуммаНДС");
		Сумма = Всего - Сведения.СуммаСкидки - ?(Сведения.СуммаВключаетНДС, 0, СуммаНДС);
	ИначеЕсли ВсегоСкидок <> 0 Тогда
		Сумма = Сумма - ВсегоСкидок;
	КонецЕсли;
	
	Возврат Новый Структура("Сумма, СуммаНДС", Сумма, СуммаНДС);
	
КонецФункции

Функция ГСК5664_ДанныеПечатиИтоговНДС(Сведения, СуммаНДС)
	
	НДСИсчисляетсяНалоговымАгентом = Сведения.НДСИсчисляетсяНалоговымАгентом = Истина
		И УчетНДС.ВедетсяУчетНДСПоФЗ335(Сведения.ДатаДляПолученияСведений);
	
	Если НДСИсчисляетсяНалоговымАгентом Тогда
		Возврат Новый Структура(
			"НДС, ВсегоНДС, СуммаНДС",
			УчетНДС.НадписьСтавкаНДСИсчисляетсяНалоговымАгентом(),
			НСтр("ru='-'"),
			НСтр("ru='-'"));
	КонецЕсли;
	
	СтавкиНДС = ОбщегоНазначения.ВыгрузитьКолонку(Сведения.ТаблицаДокумента, "СтавкаНДС", Истина);
	Данные = ПечатьТорговыхДокументов.ДанныеПечатиИтоговНДС(СуммаНДС, СтавкиНДС, Сведения.СуммаВключаетНДС, ":");
	Данные.Вставить("СуммаНДС", Данные.ВсегоНДС);
	Возврат Данные;
	
КонецФункции

Процедура ГСК5664_ВывестиСоставнуюСтрокуИтогаНДС(ТабличныйДокумент, Макет, Данные, ВыводитьКоды)
	
	ОбластьНомера = Макет.ПолучитьОбласть("ИтогоНДС|НомерСтроки");
	ОбластьКодов = Макет.ПолучитьОбласть("ИтогоНДС|КолонкаКодов");
	ОбластьДанных = Макет.ПолучитьОбласть("ИтогоНДС|Данные");
	ОбластьСуммы = Макет.ПолучитьОбласть("ИтогоНДС|Сумма");
	
	ТабличныйДокумент.Вывести(ОбластьНомера);
	Если ВыводитьКоды Тогда
		ТабличныйДокумент.Присоединить(ОбластьКодов);
	КонецЕсли;
	ОбластьДанных.Параметры.Заполнить(Данные);
	ТабличныйДокумент.Присоединить(ОбластьДанных);
	ГСК5664_ПрисоединитьКолонкиНДС(ТабличныйДокумент, Макет, "ИтогоНДС",
		Новый Структура("СуммаНДС", Данные.ВсегоНДС));
	ТабличныйДокумент.Присоединить(ОбластьСуммы);
	
КонецПроцедуры

Процедура ГСК5664_ВывестиСоставнуюСтрокуИтога(ТабличныйДокумент, Макет, ИмяОбласти, Данные, ВыводитьКоды)
	
	ОбластьНомера = Макет.ПолучитьОбласть(ИмяОбласти + "|НомерСтроки");
	ОбластьКодов = Макет.ПолучитьОбласть(ИмяОбласти + "|КолонкаКодов");
	ОбластьДанных = Макет.ПолучитьОбласть(ИмяОбласти + "|Данные");
	ОбластьСуммы = Макет.ПолучитьОбласть(ИмяОбласти + "|Сумма");
	
	ТабличныйДокумент.Вывести(ОбластьНомера);
	Если ВыводитьКоды Тогда
		ТабличныйДокумент.Присоединить(ОбластьКодов);
	КонецЕсли;
	ТабличныйДокумент.Присоединить(ОбластьДанных);
	ГСК5664_ПрисоединитьКолонкиНДС(ТабличныйДокумент, Макет, ИмяОбласти);
	ОбластьСуммы.Параметры.Заполнить(Данные);
	ТабличныйДокумент.Присоединить(ОбластьСуммы);
	
КонецПроцедуры

Процедура ГСК5664_ПрисоединитьКолонкиНДС(ТабличныйДокумент, Макет, ПрефиксОбласти, Данные = Неопределено)
	
	Если Не ГСК5664_ЕстьОбласть(Макет, ПрефиксОбласти + "|СтавкаНДС") Тогда
		Возврат;
	КонецЕсли;
	
	ОбластьСтавка = Макет.ПолучитьОбласть(ПрефиксОбласти + "|СтавкаНДС");
	Если Данные <> Неопределено Тогда
		ОбластьСтавка.Параметры.Заполнить(Данные);
	КонецЕсли;
	ТабличныйДокумент.Присоединить(ОбластьСтавка);
	
	ОбластьСуммаНДС = Макет.ПолучитьОбласть(ПрефиксОбласти + "|СуммаНДС");
	Если Данные <> Неопределено Тогда
		ОбластьСуммаНДС.Параметры.Заполнить(Данные);
	КонецЕсли;
	ТабличныйДокумент.Присоединить(ОбластьСуммаНДС);
	
КонецПроцедуры

Функция ГСК5664_ДанныеСтрокиНДС(Строка, Сведения)
	
	Данные = Новый Структура;
	НДСИсчисляетсяНалоговымАгентом = Сведения.НДСИсчисляетсяНалоговымАгентом = Истина
		И УчетНДС.ВедетсяУчетНДСПоФЗ335(Сведения.ДатаДляПолученияСведений);
	
	Если НДСИсчисляетсяНалоговымАгентом Тогда
		Данные.Вставить("СтавкаНДС", УчетНДС.НадписьСтавкаНДСИсчисляетсяНалоговымАгентом());
		Данные.Вставить("СуммаНДС", УчетНДС.НадписьСуммаНДСИсчисляетсяНалоговымАгентом());
	Иначе
		Данные.Вставить("СтавкаНДС", Строка.СтавкаНДС);
		Данные.Вставить("СуммаНДС", ОбщегоНазначенияБПВызовСервера.ФорматСумм(Строка.СуммаНДС));
	КонецЕсли;
	
	Возврат Данные;
	
КонецФункции

Процедура ГСК5664_ВывестиПодписи(ТабличныйДокумент, Макет, Сведения)
	
	СведенияОПолучателе = БухгалтерскийУчетПереопределяемый.СведенияОЮрФизЛице(
		Сведения.Получатель, Сведения.ДатаДляПолученияСведений);
	
	ДанныеПодвал = Новый Структура;
	СтатусФизЛица = Справочники.Организации.СтатусФизическогоЛицаНаДату(
		Сведения.Организация, Сведения.ДатаДляПолученияСведений);
	ЭтоСамозанятый = СтатусФизЛица = Перечисления.СтатусыФизическихЛиц.Самозанятый;
	СчетИП = СведенияОПолучателе.ЮридическоеФизическоеЛицо = Перечисления.ЮридическоеФизическоеЛицо.ФизическоеЛицо
		И (Не ЗначениеЗаполнено(Сведения.РуководительФИО)
			Или Сведения.Руководитель = СведенияОПолучателе.ИндивидуальныйПредприниматель);
	
	Если (СчетИП Или ЭтоСамозанятый) И ГСК5664_ЕстьОбласть(Макет, "ПодвалСчетаПредприниматель") Тогда
		ДанныеПодвал.Вставить("ФИОПредпринимателя", СведенияОПолучателе.ФамилияИнициалыФизлица);
		ДанныеПодвал.Вставить("Предприниматель",
			?(ЭтоСамозанятый, НСтр("ru = 'Поставщик (Исполнитель)'"), НСтр("ru = 'Предприниматель'")));
		ГСК5664_ВывестиОбласть(ТабличныйДокумент, Макет, "ПодвалСчетаПредприниматель", ДанныеПодвал);
	ИначеЕсли ГСК5664_ЕстьОбласть(Макет, "ПодвалСчета") Тогда
		ДанныеПодвал.Вставить("ФИОРуководителя", Сведения.РуководительФИО);
		ДанныеПодвал.Вставить("ФИОБухгалтера", Сведения.ГлавныйБухгалтерФИО);
		ДанныеПодвал.Вставить("ЗаРуководителяПоПриказу", Сведения.ЗаРуководителяНаОснованииНаименование);
		ДанныеПодвал.Вставить("ЗаГлавногоБухгалтераПоПриказу", Сведения.ЗаГлавногоБухгалтераНаОснованииНаименование);
		ГСК5664_ВывестиОбласть(ТабличныйДокумент, Макет, "ПодвалСчета", ДанныеПодвал);
	КонецЕсли;
	
КонецПроцедуры

Процедура ГСК5664_ПодготовитьШиринуКолонокТаблицы(Макет, ВыводитьКоды, ЕстьСкидка)
	
	ОбластьКолонкаТовар = Макет.Область("Товар");
	
	Если Не ВыводитьКоды Тогда
		ОбластьКолонкаТовар.ШиринаКолонки = ОбластьКолонкаТовар.ШиринаКолонки + Макет.Область("КолонкаКодов").ШиринаКолонки;
	КонецЕсли;
	
	Если Не ЕстьСкидка И ЗначениеЗаполнено(Макет.Области.Найти("Скидка")) Тогда
		ОбластьКолонкаТовар.ШиринаКолонки = ОбластьКолонкаТовар.ШиринаКолонки + Макет.Область("Скидка").ШиринаКолонки;
	КонецЕсли;
	
	// Не шире блока реквизитов шапки — длинные наименования переносятся в ячейке.
	Если ГСК5664_ЕстьОбласть(Макет, "Реквизиты") Тогда
		ШиринаШапки = Макет.Область("Реквизиты").ШиринаКолонки;
		Если ШиринаШапки > 0 Тогда
			ШиринаФиксированныхКолонок = Макет.Область("НомерСтроки").ШиринаКолонки
				+ (Макет.Область("Данные").ШиринаКолонки - ОбластьКолонкаТовар.ШиринаКолонки)
				+ Макет.Область("Сумма").ШиринаКолонки;
			Если ВыводитьКоды Тогда
				ШиринаФиксированныхКолонок = ШиринаФиксированныхКолонок + Макет.Область("КолонкаКодов").ШиринаКолонки;
			КонецЕсли;
			Если ЕстьСкидка Тогда
				ШиринаФиксированныхКолонок = ШиринаФиксированныхКолонок + Макет.Область("Скидка").ШиринаКолонки;
			КонецЕсли;
			Если ГСК5664_ЕстьОбласть(Макет, "СтавкаНДС") Тогда
				ШиринаФиксированныхКолонок = ШиринаФиксированныхКолонок
					+ Макет.Область("СтавкаНДС").ШиринаКолонки
					+ Макет.Область("СуммаНДС").ШиринаКолонки;
			КонецЕсли;
			МаксШиринаТовара = ШиринаШапки - ШиринаФиксированныхКолонок;
			Если МаксШиринаТовара > 0 И ОбластьКолонкаТовар.ШиринаКолонки > МаксШиринаТовара Тогда
				ОбластьКолонкаТовар.ШиринаКолонки = МаксШиринаТовара;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Функция ГСК5664_ВыводитьКодыВТаблице()
	
	Вариант = Константы.ДополнительнаяКолонкаПечатныхФормДокументов.Получить();
	Если Не ЗначениеЗаполнено(Вариант) Тогда
		Вариант = Перечисления.ДополнительнаяКолонкаПечатныхФормДокументов.НеВыводить;
	КонецЕсли;
	Возврат Вариант <> Перечисления.ДополнительнаяКолонкаПечатныхФормДокументов.НеВыводить;
	
КонецФункции

Функция ГСК5664_ИмяКолонкиКодов()
	
	Вариант = Константы.ДополнительнаяКолонкаПечатныхФормДокументов.Получить();
	Если Вариант = Перечисления.ДополнительнаяКолонкаПечатныхФормДокументов.Код Тогда
		Возврат "Код";
	КонецЕсли;
	Возврат "Артикул";
	
КонецФункции

Процедура ГСК5664_ВывестиОбласть(ТабличныйДокумент, Макет, ИмяОбласти, Данные = Неопределено)
	
	Область = ГСК5664_ПолучитьОбластьМакета(Макет, ИмяОбласти);
	Если Данные <> Неопределено Тогда
		Область.Параметры.Заполнить(Данные);
	КонецЕсли;
	ТабличныйДокумент.Вывести(Область);
	
КонецПроцедуры

Функция ГСК5664_ЕстьОбласть(Макет, ИмяОбласти)
	
	Попытка
		Макет.ПолучитьОбласть(ИмяОбласти);
		Возврат Истина;
	Исключение
		Возврат Ложь;
	КонецПопытки;
	
КонецФункции

Функция ГСК5664_СведенияСчета(СсылкаСчета)
	
	Массив = Новый Массив;
	Массив.Добавить(СсылкаСчета);
	Таблица = Документы.СчетНаОплатуПокупателю.ПолучитьТаблицуСведенийСчетаНаОплату(Массив);
	Если Таблица.Количество() = 0 Тогда
		ВызватьИсключение НСтр("ru = 'Не удалось получить сведения для печати счета.'");
	КонецЕсли;
	Возврат Таблица[0];
	
КонецФункции

Процедура ГСК5664_ВывестиЗаголовокСчета(ТабличныйДокумент, Макет, Сведения)
	
	ДанныеПечатиЗаголовокСчета = ГСК5664_ДанныеЗаголовкаСчета(Сведения);
	
	ДвоичныеДанныеКартинки = Неопределено;
	Если ТипЗнч(Сведения.Получатель) = Тип("СправочникСсылка.Организации") Тогда
		ДвоичныеДанныеКартинки = Справочники.Организации.ДвоичныеДанныеКартинкиОрганизации(
			Сведения.Получатель, "ФайлЛоготип");
	КонецЕсли;
	ЕстьЛоготип = ЗначениеЗаполнено(ДвоичныеДанныеКартинки);
	
	ДвоичныеДанныеQRКода = ГСК5664_ДвоичныеДанныеQRКода(Сведения, ДанныеПечатиЗаголовокСчета);
	ЕстьQR = ЗначениеЗаполнено(ДвоичныеДанныеQRКода);
	
	Если ГСК5664_ЕстьОбласть(Макет, "QRКод") И ГСК5664_ЕстьОбласть(Макет, "ЗаголовокСчета|Реквизиты") Тогда
		
		НачалоНовогоФормата = ТабличныйДокумент.ВысотаТаблицы + 1;
		
		Если Не ЕстьQR Тогда
			ОбластьРеквизитыПраво = Макет.Область("РеквизитыПраво");
			ОбластьРеквизитыПраво.ШиринаКолонки = ОбластьРеквизитыПраво.ШиринаКолонки + Макет.Область("QRКод").ШиринаКолонки;
		КонецЕсли;
		
		Если ЕстьЛоготип И ГСК5664_ЕстьОбласть(Макет, "ЗаголовокСчетаСЛоготипом|Реквизиты") Тогда
			ИмяЗаголовка = "ЗаголовокСчетаСЛоготипом";
			ИмяРисункаQR = "РисунокQRЛоготип";
		Иначе
			ИмяЗаголовка = "ЗаголовокСчета";
			ИмяРисункаQR = "РисунокQR";
		КонецЕсли;
		
		ОбластьРеквизиты = Макет.ПолучитьОбласть(ИмяЗаголовка + "|Реквизиты");
		ОбластьQR = Макет.ПолучитьОбласть(ИмяЗаголовка + "|QRКод");
		
		Если ЕстьЛоготип И ИмяЗаголовка = "ЗаголовокСчетаСЛоготипом" Тогда
			Попытка
				ОбластьРеквизиты.Рисунки.ЛоготипСчета.Картинка = Новый Картинка(ДвоичныеДанныеКартинки);
			Исключение
				ЗаписьЖурналаРегистрации(
					НСтр("ru = 'Печать счета-оферта'"),
					УровеньЖурналаРегистрации.Ошибка,
					Метаданные.Документы.СчетНаОплатуПокупателю,
					Сведения.Документ,
					НСтр("ru = 'Не удалось получить логотип'"));
			КонецПопытки;
		КонецЕсли;
		
		ОбластьРеквизиты.Параметры.Заполнить(Сведения);
		ОбластьРеквизиты.Параметры.Заполнить(ДанныеПечатиЗаголовокСчета);
		ТабличныйДокумент.Вывести(ОбластьРеквизиты);
		
		Если ЕстьQR Тогда
			ОбластьРисунка = ОбластьQR.Области.Найти(ИмяРисункаQR);
			Если ОбластьРисунка <> Неопределено Тогда
				ОбластьРисунка.Картинка = Новый Картинка(ДвоичныеДанныеQRКода);
				ТабличныйДокумент.Присоединить(ОбластьQR);
			КонецЕсли;
		КонецЕсли;
		
		ТабличныйДокумент.Область(НачалоНовогоФормата,, ТабличныйДокумент.ВысотаТаблицы).СоздатьФорматСтрок();
		
	Иначе
		
		Если ЕстьЛоготип И ГСК5664_ЕстьОбласть(Макет, "ЗаголовокСчетаСЛоготипом") Тогда
			ОбластьМакета = Макет.ПолучитьОбласть("ЗаголовокСчетаСЛоготипом");
			Попытка
				ОбластьМакета.Рисунки.ЛоготипСчета.Картинка = Новый Картинка(ДвоичныеДанныеКартинки);
			Исключение
				ЗаписьЖурналаРегистрации(
					НСтр("ru = 'Печать счета-оферта'"),
					УровеньЖурналаРегистрации.Ошибка,
					Метаданные.Документы.СчетНаОплатуПокупателю,
					Сведения.Документ,
					НСтр("ru = 'Не удалось получить логотип'"));
			КонецПопытки;
		Иначе
			ОбластьМакета = Макет.ПолучитьОбласть("ЗаголовокСчета");
		КонецЕсли;
		
		ОбластьМакета.Параметры.Заполнить(Сведения);
		ОбластьМакета.Параметры.Заполнить(ДанныеПечатиЗаголовокСчета);
		ТабличныйДокумент.Вывести(ОбластьМакета);
		
	КонецЕсли;
	
КонецПроцедуры

Функция ГСК5664_ДвоичныеДанныеQRКода(Сведения, ДанныеПечатиЗаголовокСчета)
	
	СведенияОПокупателе = БухгалтерскийУчетПереопределяемый.СведенияОЮрФизЛице(
		Сведения.Покупатель, Сведения.ДатаДляПолученияСведений);
	СчетВВалюте = Сведения.Валюта
		<> ОбщегоНазначенияБПВызовСервераПовтИсп.ПолучитьВалютуРегламентированногоУчета();
	
	Если СведенияОПокупателе.ЮридическоеФизическоеЛицо <> Перечисления.ЮридическоеФизическоеЛицо.ФизическоеЛицо
		Или СчетВВалюте Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	СуммаНДС = Сведения.ТаблицаДокумента.Итог("СуммаНДС");
	ДанныеПечатиИтоговНДС = ГСК5664_ДанныеПечатиИтоговНДС(Сведения, СуммаНДС);
	
	РеквизитыПлатежа = ОбщегоНазначенияБП.НовыйРеквизитыПлатежаУФЭБС();
	ЗаполнитьЗначенияСвойств(РеквизитыПлатежа, ДанныеПечатиЗаголовокСчета);
	
	Если Сведения.ДополнительныеРеквизитыQRКода <> Неопределено Тогда
		ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(
			РеквизитыПлатежа, Сведения.ДополнительныеРеквизитыQRКода, Истина);
	КонецЕсли;
	
	РеквизитыПлатежа.ТекстПолучателя = ДанныеПечатиЗаголовокСчета.ПредставлениеПолучателя;
	РеквизитыПлатежа.НомерСчетаПолучателя = ДанныеПечатиЗаголовокСчета.СчетПолучателя;
	РеквизитыПлатежа.НаименованиеБанкаПолучателя = ДанныеПечатиЗаголовокСчета.БанкПолучателяПредставление;
	РеквизитыПлатежа.БИКБанкаПолучателя = ДанныеПечатиЗаголовокСчета.БИКБанкаПолучателя;
	РеквизитыПлатежа.СчетБанкаПолучателя = ДанныеПечатиЗаголовокСчета.СчетБанкаПолучателя;
	РеквизитыПлатежа.ИННПолучателя = ДанныеПечатиЗаголовокСчета.ИННПолучателя;
	РеквизитыПлатежа.КПППолучателя = ДанныеПечатиЗаголовокСчета.КПППолучателя;
	
	СкидкиПоДокументу = Сведения.ТаблицаДокумента.Итог("СуммаСкидки") + Сведения.СуммаСкидки;
	СуммаКОплате = Сведения.ТаблицаДокумента.Итог("Сумма") - СкидкиПоДокументу;
	Если Не Сведения.СуммаВключаетНДС Тогда
		СуммаКОплате = СуммаКОплате + Сведения.ТаблицаДокумента.Итог("СуммаНДС");
	КонецЕсли;
	РеквизитыПлатежа.СуммаЧислом = СуммаКОплате;
	
	ТекстПроНДС = ДанныеПечатиИтоговНДС.НДС;
	Если ДанныеПечатиИтоговНДС.ВсегоНДС <> "-" Тогда
		ТекстПроНДС = ТекстПроНДС + ДанныеПечатиИтоговНДС.ВсегоНДС;
	КонецЕсли;
	РеквизитыПлатежа.НазначениеПлатежа = СтрШаблон(
		НСтр("ru = 'Оплата по счету № %1 от %2. Сумма %3. %4.'"),
		Сведения.НомерДокумента,
		Формат(Сведения.ДатаДокумента, "ДФ=dd.MM.yyyy"),
		Формат(СуммаКОплате, "ЧЦ=15; ЧДЦ=2; ЧРД=-; ЧН=0-00; ЧГ="),
		ТекстПроНДС);
	
	QRСтрока = УправлениеПечатьюРФ.ФорматнаяСтрокаУФЭБС(РеквизитыПлатежа);
	Если ПустаяСтрока(QRСтрока) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ДанныеQRКода = ГенерацияШтрихкода.ДанныеQRКода(QRСтрока, 0, 190);
	Если ТипЗнч(ДанныеQRКода) <> Тип("ДвоичныеДанные") Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат ДанныеQRКода;
	
КонецФункции

Функция ГСК5664_ДанныеЗаголовкаСчета(Сведения)
	
	СведенияОПолучателе = БухгалтерскийУчетПереопределяемый.СведенияОЮрФизЛице(
		Сведения.Получатель, Сведения.ДатаДляПолученияСведений);
	
	Данные = Новый Структура;
	Данные.Вставить("ИННПолучателя", СведенияОПолучателе.ИНН);
	Данные.Вставить("КПППолучателя", СведенияОПолучателе.КПП);
	
	Если ТипЗнч(Сведения.БанковскийСчетПродавца) = Тип("СправочникСсылка.БанковскиеСчета") Тогда
		Данные.Вставить("БИКБанкаПолучателя", Сведения.БикБанкаПолучателя);
		Данные.Вставить("БанкПолучателя", Сведения.БанкПолучателя);
		Данные.Вставить("БанкПолучателяПредставление", СокрЛП(Сведения.НаименованиеБанкаПолучателя));
		Данные.Вставить("СчетБанкаПолучателя", Сведения.СчетБанкаПолучателя);
		Данные.Вставить("СчетБанкаПолучателяПредставление", Сведения.СчетБанкаПолучателя);
		Данные.Вставить("СчетПолучателяПредставление", Сведения.НомерСчетаПолучателя);
		Данные.Вставить("СчетПолучателя", Сведения.НомерСчетаПолучателя);
	КонецЕсли;
	
	ПредставлениеПолучателя = УчетДенежныхСредствБП.СформироватьТекстНаименованияПлательщикаПолучателя(
		, Сведения.Получатель, Сведения.БанковскийСчетПродавца, , Сведения.ДатаДляПолученияСведений);
	Данные.Вставить("ПредставлениеПолучателя", ПредставлениеПолучателя);
	
	Возврат Данные;
	
КонецФункции

Функция ГСК5664_ДанныеШапки(СсылкаСчета, Сведения)
	
	СведенияОПоставщике = БухгалтерскийУчетПереопределяемый.СведенияОЮрФизЛице(
		Сведения.Поставщик, Сведения.ДатаДляПолученияСведений);
	СведенияОПокупателе = БухгалтерскийУчетПереопределяемый.СведенияОЮрФизЛице(
		Сведения.Покупатель, Сведения.ДатаДляПолученияСведений);
	
	Данные = Новый Структура;
	Данные.Вставить("ТекстЗаголовка",
		СтрШаблон(НСтр("ru = 'СЧЕТ-ОФЕРТА № %1 от %2'"),
			Сведения.НомерДокумента,
			Формат(Сведения.ДатаДокумента, "ДЛФ=D")));
	Данные.Вставить("ПредставлениеПоставщика",
		ОбщегоНазначенияБПВызовСервера.ОписаниеОрганизации(
			СведенияОПоставщике, "НаименованиеДляПечатныхФорм,ИНН,КПП,ЮридическийАдрес,Телефоны,"));
	Данные.Вставить("ПредставлениеПокупателя",
		ОбщегоНазначенияБПВызовСервера.ОписаниеОрганизации(
			СведенияОПокупателе, "НаименованиеДляПечатныхФорм,ИНН,КПП,ЮридическийАдрес,Телефоны,"));
	
	Данные.Вставить("Основание", ГСК5664_ТекстОснованияОферты());
	Данные.Вставить("ТекстДополнительныхУсловий", ГСК5664_ТекстУсловийОферты(Сведения));
	
	Возврат Данные;
	
КонецФункции

Функция ГСК5664_ТекстОснованияОферты()
	
	Возврат НСтр("ru = 'Договор не заключался. Настоящий счет является офертой (ст. 435 ГК РФ); акцепт — полная оплата по реквизитам счета (ст. 438 ГК РФ).'");
	
КонецФункции

Функция ГСК5664_ТекстУсловийОферты(Сведения)
	
	Части = Новый Массив;
	Если ЗначениеЗаполнено(Сведения.ТекстДополнительныхУсловий) Тогда
		Части.Добавить(СокрЛП(Сведения.ТекстДополнительныхУсловий));
	КонецЕсли;
	Части.Добавить(НСтр("ru = 'Настоящий документ является офертой (ст. 435 ГК РФ) на заключение договора купли-продажи (оказания услуг) на условиях, указанных в табличной части.'"));
	Части.Добавить(НСтр("ru = 'Акцепт оферты — полная оплата по реквизитам, указанным в счете, в течение срока действия счета (если срок не указан — 10 календарных дней с даты счета).'"));
	Возврат СтрСоединить(Части, Символы.ПС + Символы.ПС);
	
КонецФункции

Функция ГСК5664_ПолучитьОбластьМакета(Макет, ИмяОбласти)
	
	Попытка
		Возврат Макет.ПолучитьОбласть(ИмяОбласти);
	Исключение
		ВызватьИсключение СтрШаблон(НСтр("ru = 'В макете не найдена область: %1'"), ИмяОбласти);
	КонецПопытки;
	
КонецФункции

#КонецОбласти
