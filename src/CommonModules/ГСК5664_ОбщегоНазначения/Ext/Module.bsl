// Идея 1Фреш #5664 — счет-оферта / счет-договор для БП.

#Область ПрограммныйИнтерфейс

// Регистрация печатной формы после заимствования документа (см. docs/BORROW.md).
Процедура ДобавитьПечатнуюФормуСчетОферта(КоллекцияПечатныхФорм, ОбъектыПечати) Экспорт
	
	Если КоллекцияПечатныхФорм.Найти("ГСК5664_СчетОферта", "ИмяМакета") <> Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	КоллекцияПечатныхФорм.Добавить("ГСК5664_СчетОферта", "Счет-оферта", ,
		"Обработка.ГСК5664_ПечатьСчетОферта.Печать");
	
КонецПроцедуры

#КонецОбласти
