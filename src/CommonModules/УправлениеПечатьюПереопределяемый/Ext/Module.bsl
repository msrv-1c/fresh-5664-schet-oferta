&НаСервере
&После("ПриПолученииКомандПечати")
Процедура ГСК5664_ПриПолученииКомандПечати(Знач ПолноеИмяОбъектаМетаданных, КомандыПечати)
	
	Если ПолноеИмяОбъектаМетаданных <> "Документ.СчетНаОплатуПокупателю" Тогда
		Возврат;
	КонецЕсли;
	
	КомандаПечати = КомандыПечати.Добавить();
	КомандаПечати.МенеджерПечати = "Обработка.ГСК5664_ПечатьСчетОферта";
	КомандаПечати.Идентификатор = "ГСК5664_СчетОферта";
	КомандаПечати.Представление = НСтр("ru = 'Счет-оферта'");
	КомандаПечати.ЗаголовокФормы = НСтр("ru = 'Счет-оферта'");
	КомандаПечати.Обработчик = "УправлениеПечатьюБПКлиент.ВыполнитьКомандуПечати";
	КомандаПечати.Порядок = 15;
	
КонецПроцедуры

&НаСервере
&После("ПечатьДокументовПриСозданииНаСервере")
Процедура ГСК5664_ПечатьДокументовПриСозданииНаСервере(Форма, Отказ, СтандартнаяОбработка)
	
	Если Не ГСК5664_ФормаСчетОферта(Форма) Тогда
		Возврат;
	КонецЕсли;
	
	Если Форма.Элементы.Найти("ГСК5664_НадписьКонвейер1С") <> Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	КнопкаЕще = ГСК5664_НайтиКнопкуЕще(Форма);
	НадписьКонвейер = Неопределено;
	
	Если КнопкаЕще <> Неопределено Тогда
		Попытка
			НадписьКонвейер = Форма.Элементы.Вставить("ГСК5664_НадписьКонвейер1С",
				Тип("ДекорацияФормы"), Форма.Элементы.ГруппаКоманднаяПанель, КнопкаЕще);
		Исключение
			Попытка
				НадписьКонвейер = Форма.Элементы.Вставить("ГСК5664_НадписьКонвейер1С",
					Тип("ДекорацияФормы"), КнопкаЕще.Родитель, КнопкаЕще);
			Исключение
				НадписьКонвейер = Форма.Элементы.Найти("ГСК5664_НадписьКонвейер1С");
			КонецПопытки;
		КонецПопытки;
	КонецЕсли;
	
	Если НадписьКонвейер = Неопределено Тогда
		НадписьКонвейер = Форма.Элементы.Добавить("ГСК5664_НадписьКонвейер1С",
			Тип("ДекорацияФормы"), Форма.Элементы.ГруппаКоманднаяПанель);
	КонецЕсли;
	НадписьКонвейер.Вид = ВидДекорацииФормы.Надпись;
	
	ЧастиНадписи = Новый Массив;
	ЧастиНадписи.Добавить(Новый ФорматированнаяСтрока(НСтр("ru = 'Сделано на Конвейере 1С: '")));
	ЧастиНадписи.Добавить(Новый ФорматированнаяСтрока(
		"https://gitsell.ru/1c", , ЦветаСтиля.ГиперссылкаЦвет, , "https://gitsell.ru/1c"));
	НадписьКонвейер.Заголовок = Новый ФорматированнаяСтрока(ЧастиНадписи);
	НадписьКонвейер.ВертикальноеПоложениеВГруппе = ВертикальноеПоложениеЭлемента.Центр;
	НадписьКонвейер.УстановитьДействие(
		"ОбработкаНавигационнойСсылки", "Подключаемый_ОбработкаНавигационнойСсылки");
	
КонецПроцедуры

&НаСервере
Функция ГСК5664_ФормаСчетОферта(Форма)
	
	Для Каждого НастройкаПечатнойФормы Из Форма.НастройкиПечатныхФорм Цикл
		Если НастройкаПечатнойФормы.ИмяМакета = "ГСК5664_СчетОферта" Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Ложь;
	
КонецФункции

&НаСервере
Функция ГСК5664_НайтиКнопкуЕще(Форма)
	
	ИменаКнопкиЕще = Новый Массив;
	ИменаКнопкиЕще.Добавить("Еще");
	ИменаКнопкиЕще.Добавить("ФормаЕще");
	
	Для Каждого ИмяКнопки Из ИменаКнопкиЕще Цикл
		КнопкаЕще = Форма.Элементы.Найти(ИмяКнопки);
		Если КнопкаЕще <> Неопределено Тогда
			Возврат КнопкаЕще;
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого ЭлементФормы Из Форма.Элементы Цикл
		Попытка
			Если ЭлементФормы.Заголовок = НСтр("ru = 'Еще'") Тогда
				Возврат ЭлементФормы;
			КонецЕсли;
		Исключение
		КонецПопытки;
	КонецЦикла;
	
	Возврат Неопределено;
	
КонецФункции
